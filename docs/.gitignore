# Astro build output
dist/

# Astro generated types
.astro/

# Yarn PnP project — no node_modules directory is used
node_modules/

# Yarn: the plugins and editor SDKs are committed; the dependency cache and
# other local state are not (CI restores the cache with actions/cache).
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Environment files
.env
.env.production

# Logs and OS cruft
*.log
.DS_Store
